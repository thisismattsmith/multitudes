---
import Base from '../layouts/Base.astro';

// Status types: 'active' | 'acquired' | 'for-sale' | 'closed'
const ventures = [
  {
    est: '2026',
    title: 'The Learning Dept.',
    blurb: 'Scaling and supporting L&D teams.',
    url: 'thelearningdept.com.au',
    href: 'https://thelearningdept.com.au',
    status: 'active',
  },
  {
    est: '2026',
    title: 'Distil',
    blurb: 'A studio helping self-employed experts — consultants, freelancers, and coaches — turn their expertise into training.',
    url: 'distilstudio.com.au',
    href: 'https://distilstudio.com.au',
    status: 'active',
  },
  {
    est: '2026',
    title: 'Waymark',
    blurb: 'Customer education strategy and execution for startups and scale-ups.',
    url: 'waymark.com.au',
    href: 'https://waymark.com.au',
    status: 'active',
  },
  {
    est: '2026',
    title: 'The eLearning Company',
    blurb: 'Changing the model for eLearning development.',
    url: 'elearningcompany.net',
    href: 'https://elearningcompany.net',
    status: 'active',
  },
];

const projects = [
  {
    est: '2026',
    title: 'The Future of Learning & Development',
    blurb: 'Notes, essays, and occasional long-form on the practice of building.',
    url: 'futureoflearninganddevelopment.com ',
    href: 'https://futureoflearninganddevelopment.com ',
    status: 'active',
  },
];

const statusLabel = {
  'active': 'Active',
  'acquired': 'Acquired',
  'for-sale': 'For Sale',
  'closed': 'Closed',
} as const;
---

<Base title="Made by Multitudes — Businesses to help you learn and grow" page="home">
  <section class="intro reveal">
    <h1 class="hero-mark">made by multitudes</h1>
    <p>
      We create products, services and brands that focus on learning and growth.
    </p>
  </section>

  <section style="margin-bottom: 5rem;">
    <h2 class="section-label">Current Ventures</h2>
    <ul class="index reveal-stagger">
      {ventures.map((v) => (
        <li class="index__item">
          <a href={v.href}>
            <span class="index__est">est. {v.est}</span>
            <span class="index__title">
              {v.title}
              <em>{v.blurb}</em>
              <span class="index__url">{v.url}</span>
            </span>
            <span class={`index__status status-${v.status}`}>
              <span class="status-dot" aria-hidden="true"></span>
              {statusLabel[v.status as keyof typeof statusLabel]}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section hidden>
    <h2 class="section-label">Projects, Products &amp; Publications</h2>
    <ul class="index">
      {projects.map((p) => (
        <li class="index__item">
          <a href={p.href}>
            <span class="index__est">est. {p.est}</span>
            <span class="index__title">
              {p.title}
              <em>{p.blurb}</em>
              <span class="index__url">{p.url}</span>
            </span>
            <span class={`index__status status-${p.status}`}>
              <span class="status-dot" aria-hidden="true"></span>
              {statusLabel[p.status as keyof typeof statusLabel]}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
