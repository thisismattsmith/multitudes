---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
  }).toUpperCase();

// group by year
const byYear: Record<string, typeof posts> = {};
for (const p of posts) {
  const y = String(p.data.date.getFullYear());
  (byYear[y] ||= []).push(p);
}
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<Base title="Journal — Made by Multitudes" page="journal">
  <section class="intro reveal">
    <p class="mono" style="margin-bottom: 1rem;">Journal</p>
    <h1>Notes on the work, our progress and what we've learned.</h1>
    <p>
      Annual letters and occasional company updates.
    </p>
  </section>

  {years.map((year) => (
    <section style="margin-bottom: 4rem;">
      <h2 class="section-label">{year}</h2>
      <ul class="index index--journal">
        {byYear[year].map((p) => (
          <li class="index__item">
            <a href={`/journal/${p.id}`}>
              <span class="index__est">{fmt(p.data.date)}</span>
              <span class="index__title">
                {p.data.title}
                {p.data.description && <em>{p.data.description}</em>}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>
